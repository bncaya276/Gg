local Player = game.Players.LocalPlayer
local speedOn, invisOn, hitOn = false, false, false
local SavedPos = nil

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "Delta_V3_Fix"
ScreenGui.Parent = Player:WaitForChild("PlayerGui")
ScreenGui.ResetOnSpawn = false

local Main = Instance.new("Frame")
Main.Size = UDim2.new(0, 200, 0, 320)
Main.Position = UDim2.new(0.5, -100, 0.2, 0)
Main.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
Main.Active, Main.Draggable = true, true
Main.Parent = ScreenGui
Instance.new("UICorner", Main)

local function createBtn(text, pos, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Position = pos
    btn.Text = text
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Parent = Main
    Instance.new("UICorner", btn)
    return btn
end

-- 1, 2, 3: TELEPORT
createBtn("Lưu Khu Vực", UDim2.new(0.05, 0, 0.05, 0), Color3.fromRGB(0, 80, 200)).MouseButton1Click:Connect(function()
    if Player.Character then SavedPos = Player.Character.HumanoidRootPart.CFrame end
end)

createBtn("Đến Khu Vực", UDim2.new(0.05, 0, 0.18, 0), Color3.fromRGB(0, 150, 80)).MouseButton1Click:Connect(function()
    if SavedPos and Player.Character then Player.Character.HumanoidRootPart.CFrame = SavedPos end
end)

createBtn("Xóa Khu Vực", UDim2.new(0.05, 0, 0.31, 0), Color3.fromRGB(150, 0, 0)).MouseButton1Click:Connect(function()
    SavedPos = nil
end)

-- 4: HITBOX (FIX LỖI LÚN)
local Hbtn = createBtn("Hitbox Small: OFF", UDim2.new(0.05, 0, 0.44, 0), Color3.fromRGB(80, 80, 80))
Hbtn.MouseButton1Click:Connect(function()
    hitOn = not hitOn
    local char = Player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        if hitOn then
            char.HumanoidRootPart.Size = Vector3.new(0.1, 0.1, 0.1)
            char.Humanoid.HipHeight = 1.0 -- Nâng nhẹ chân để không lún
            Hbtn.Text = "Hitbox Small: ON"
            Hbtn.BackgroundColor3 = Color3.fromRGB(200, 150, 0)
        else
            char.HumanoidRootPart.Size = Vector3.new(2, 2, 1)
            char.Humanoid.HipHeight = 0
            char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
            Hbtn.Text = "Hitbox Small: OFF"
            Hbtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        end
    end
end)

-- 5: CHẠY NHANH (SPEED)
local Sbtn = createBtn("Chạy Nhanh: OFF", UDim2.new(0.05, 0, 0.57, 0), Color3.fromRGB(60, 60, 60))
Sbtn.MouseButton1Click:Connect(function()
    speedOn = not speedOn
    Sbtn.Text = speedOn and "Chạy Nhanh: ON" or "Chạy Nhanh: OFF"
    Sbtn.BackgroundColor3 = speedOn and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(60, 60, 60)
end)

-- 6: TÀNG HÌNH (INVIS)
local Ibtn = createBtn("Tàng Hình: OFF", UDim2.new(0.05, 0, 0.70, 0), Color3.fromRGB(60, 60, 60))
Ibtn.MouseButton1Click:Connect(function()
    invisOn = not invisOn
    Ibtn.Text = invisOn and "Tàng Hình: ON" or "Tàng Hình: OFF"
    for _, v in pairs(Player.Character:GetDescendants()) do
        if (v:IsA("BasePart") or v:IsA("Decal")) and v.Name ~= "HumanoidRootPart" then
            v.Transparency = invisOn and 1 or 0
        end
    end
end)

-- Vòng lặp duy trì Speed
task.spawn(function()
    while true do
        if speedOn and Player.Character and Player.Character:FindFirstChild("Humanoid") then
            Player.Character.Humanoid.WalkSpeed = 100
        end
        task.wait(0.1)
    end
end)
